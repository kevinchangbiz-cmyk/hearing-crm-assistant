# ===== NextAuth =====
# 本機開發用 http://localhost:3000；部署後改成正式網址
NEXTAUTH_URL=http://localhost:3000
# 產生方式： openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-secret

# ===== Google OAuth（僅用於登入辨識身分）=====
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ===== Gemini =====
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# 可選，預設 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ===== Service Account（統一寫入 Sheet / 建立日曆）=====
# Google Cloud > IAM & Admin > Service Accounts 建立後產生 JSON 金鑰
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@your-project.iam.gserviceaccount.com
# private_key 整段用雙引號包起來、換行以 \n 表示
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===== 店別 / 權限設定 =====
# 本機：直接編輯 config/stores.json 即可，可不設此變數。
# Vercel 部署：因 config/stores.json 不進版控，請把整份 JSON 壓成一行貼到這裡。
# STORES_CONFIG={"stores":[...],"permissions":[...]}
